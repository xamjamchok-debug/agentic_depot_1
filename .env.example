# Anthropic API Key — https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Azure Table Storage — Connection String aus Azure Portal
# Storage Account → Access Keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Tavily Web Search API — https://app.tavily.com (Block 4)
TAVILY_API_KEY=tvly-...

# Azure Communication Services — für E-Mail-Alerts (Block 4)
# Communication Services → Keys → Connection string
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://...;accesskey=...
ALERT_EMAIL_FROM=DoNotReply@...
ALERT_EMAIL_TO=deine@email.de

# App-Konfiguration
PORT=3000
NODE_ENV=development
